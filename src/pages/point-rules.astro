---
import SiteLayout from "../layouts/SiteLayout.astro";

const scoringRules = [
  {
    label: "🏃 Appearance",
    points: "+2 pts",
    detail: "A player earns appearance points when they are recorded as playing in a published matchday result.",
  },
  {
    label: "⚽ Goal",
    points: "+5 pts",
    detail: "A player earns five points for each goal scored for their own side.",
  },
  {
    label: "🎯 Assist",
    points: "+4 pts",
    detail: "A player earns four points for each confirmed assist attached to a goal.",
  },
  {
    label: "🧱 Back-line bonus",
    points: "+2 pts",
    detail: "Goalkeepers and defenders can earn a two-point bonus when their side keeps a clean sheet and the event result marks them eligible.",
  },
  {
    label: "🥅 Own goal",
    points: "-2 pts",
    detail: "A player loses two points for each own goal.",
  },
  {
    label: "🟨 Yellow card",
    points: "-1 pt",
    detail: "A player loses one point for each yellow card.",
  },
  {
    label: "🟥 Red card",
    points: "-3 pts",
    detail: "A player loses three points for each red card.",
  },
  {
    label: "©️ Captain",
    points: "x2",
    detail: "Your captain's player score is doubled if they appear. If they do not appear, your vice-captain can receive the double instead.",
  },
];
---

<SiteLayout
  title="Point Rules"
  description="Learn how Campus XI points work for fantasy football events and how hosts can bring Campus XI to their games."
>
  <section class="hero-panel hero-panel--single">
    <div class="hero-copy">
      <p class="eyebrow">Point rules</p>
      <h1>Every match action can move the leaderboard.</h1>
      <p class="hero-text">
        You earn points from the performances of the players in your starting
        squad. Pick your starters, choose a captain and vice-captain, then climb
        the table when matchday results are published.
      </p>
    </div>
  </section>

  <section class="section-shell point-rules-shell">
    <div class="section-heading">
      <p class="eyebrow">Main rule</p>
      <h2>Your starters score for your team.</h2>
    </div>

    <div class="rules-grid rules-grid--three">
      <article class="rule-card">
        <p class="rule-card__label">👥 Starters</p>
        <h3>Squad points</h3>
        <p>
          Your matchday score comes from the players in your starting squad.
          Their player points are added to your team total.
        </p>
      </article>

      <article class="rule-card">
        <p class="rule-card__label">©️ Captain</p>
        <h3>x2 if they play</h3>
        <p>
          If your captain appears in the matchday results, their player score is
          doubled for your team.
        </p>
      </article>

      <article class="rule-card">
        <p class="rule-card__label">🅥 Vice-captain</p>
        <h3>Backup x2</h3>
        <p>
          If your captain does not appear, your vice-captain can receive the
          double instead if they appear.
        </p>
      </article>
    </div>
  </section>

  <section class="section-shell point-rules-shell">
    <div class="section-heading">
      <p class="eyebrow">Player actions</p>
      <h2>How each player earns or loses points.</h2>
    </div>

    <div class="rules-grid">
      {
        scoringRules.map((rule) => (
          <article class="rule-card">
            <p class="rule-card__label">{rule.label}</p>
            <h3>{rule.points}</h3>
            <p>{rule.detail}</p>
          </article>
        ))
      }
    </div>

    <p class="small-note">
      Player points come from published matchday results. Your team total uses
      the players in your starting squad, your captain or vice-captain bonus,
      and any transfer penalties applied for that matchday.
    </p>
  </section>

  <section class="section-shell section-shell--split">
    <article class="spotlight-card">
      <p class="eyebrow">For players</p>
      <h2>Pick your squad and follow the action.</h2>
      <p>
        Campus XI gives fans a reason to track every goal, card, clean sheet, and
        comeback while the event is live.
      </p>
      <a class="text-link" href="/install">Install Campus XI</a>
    </article>

    <article class="spotlight-card spotlight-card--soft">
      <p class="eyebrow">For hosts</p>
      <h2>Want Campus XI at your football event?</h2>
      <p>
        Bring a fantasy leaderboard to your tournament, campus league, or match
        day. Contact us with your event name, date, location, and expected team
        count.
      </p>
      <a class="text-link" href="mailto:support@campusxi.com?subject=Host%20a%20Campus%20XI%20game">Contact us to host games</a>
    </article>
  </section>
</SiteLayout>
