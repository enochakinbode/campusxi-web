---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Home"
  description="Campus XI is the fantasy football destination built around campus football culture, installs, support, and policies."
>
  <section class="hero-panel hero-panel--landing hero-panel--single home-hero">
    <div class="hero-copy">
      <p class="eyebrow">Campus XI</p>
      <h1>Fantasy football for football events.</h1>
      <p class="hero-text">
        Join events, follow the action, build your squad, make your strategy,
        and chase points on the leaderboard.
      </p>
    </div>
  </section>

  <section class="section-shell section-shell--split">
    <article class="spotlight-card">
      <p class="eyebrow">Install</p>
      <h2>Get ready for Campus XI.</h2>
      <p>
        Open the install page for Campus XI on the App Store and Google Play.
      </p>
      <a class="text-link" href="/install">Open install page</a>
    </article>

    <article class="spotlight-card">
      <p class="eyebrow">Host games</p>
      <h2>Bring Campus XI to your football event.</h2>
      <p>
        Add a fantasy leaderboard to your tournament, campus league, or match
        day and give fans more reasons to follow every play.
      </p>
      <div class="inline-links">
        <a class="text-link" href="/point-rules">See point rules</a>
        <a class="text-link" href="mailto:support@campusxi.com?subject=Host%20a%20Campus%20XI%20game">Contact us</a>
      </div>
    </article>
  </section>
</SiteLayout>
