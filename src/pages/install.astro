---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Install"
  description="Get ready to install Campus XI from the App Store or Google Play once the public launch is live."
>
  <section class="hero-panel hero-panel--single">
    <div class="hero-copy">
      <p class="eyebrow">Install</p>
      <h1 class="install-title">Get ready to install Campus XI.</h1>
      <p class="hero-text">
        The app is preparing for public release on the App Store and Google
        Play.
      </p>

      <div class="store-grid" aria-label="Store availability">
        <article class="store-card store-card--apple">
          <div class="store-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="presentation">
              <path
                fill="currentColor"
                d="M15.2 3.3c0 1-.4 2-1 2.7-.7.9-1.8 1.5-2.9 1.4-.1-1 .3-2 1-2.8.7-.8 1.9-1.4 2.9-1.3ZM18.8 17.4c-.5 1.1-.8 1.6-1.4 2.5-.9 1.3-2.1 2.9-3.7 2.9-1.4 0-1.8-.9-3.5-.9-1.8 0-2.2.9-3.6.9-1.6 0-2.7-1.4-3.7-2.7C.2 16.4-.1 12.1 1.8 9.2c1.3-2.1 3.4-3.3 5.4-3.3 1.5 0 2.7 1 3.5 1 .7 0 2.2-1.2 4.1-1 1.7.1 3 .8 3.9 2.1-3.4 1.8-2.8 6.6.1 7.8Z"
              />
            </svg>
          </div>
          <div class="store-card__body">
            <p class="store-card__label">Download on the</p>
            <h2>App Store</h2>
            <p>Coming soon.</p>
          </div>
        </article>

        <article class="store-card store-card--play">
          <div class="store-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="presentation">
              <path fill="#34a853" d="M3.5 2.8 13.8 13 3.6 23.2A2.2 2.2 0 0 1 3 21.6V4.4c0-.6.2-1.2.5-1.6Z" />
              <path fill="#4285f4" d="m17 16.2-3.2-3.2L3.5 2.8c.1-.1.2-.2.4-.2.4-.2.9-.1 1.3.1L21 11.4c.4.2.7.6.7 1s-.3.8-.7 1L17 16.2Z" />
              <path fill="#fbbc04" d="m3.5 23.2 10.3-10.2 3.2 3.2-11.8 6.5c-.6.3-1.3.4-1.7.1Z" />
              <path fill="#ea4335" d="M17 16.2 21 14c.4-.2.7-.6.7-1s-.3-.8-.7-1L17 9.8 13.8 13l3.2 3.2Z" />
            </svg>
          </div>
          <div class="store-card__body">
            <p class="store-card__label">Get it on</p>
            <h2>Google Play</h2>
            <p>Coming soon.</p>
          </div>
        </article>
      </div>

      <p class="small-note">
        Need access before launch? Email
        <a href="mailto:support@campusxi.com">support@campusxi.com</a>.
      </p>
    </div>

  </section>

  <section class="section-shell section-shell--split">
    <article class="spotlight-card">
      <p class="eyebrow">Useful links</p>
      <h2>Useful pages for launch questions.</h2>
      <div class="inline-links">
        <a class="text-link" href="/help-center">Visit Help Center</a>
        <a class="text-link" href="/privacy-policy">Read Privacy Policy</a>
        <a class="text-link" href="/terms-of-use">Read Terms of Use</a>
      </div>
    </article>

    <article class="spotlight-card spotlight-card--soft">
      <p class="eyebrow">Early access</p>
      <h2>Need help before the stores go live?</h2>
      <p>
        For pre-launch installs, testing, or rollout questions, send a note to
        support and include the device type you want to test with.
      </p>
      <a class="text-link" href="mailto:support@campusxi.com">Email support</a>
    </article>
  </section>
</SiteLayout>
