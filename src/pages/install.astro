---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Install"
  description="Install CampusXI from App Store or Play Store once live."
>
  <section class="card hero">
    <p class="badge">CampusXI Install</p>
    <h1>Get CampusXI</h1>
    <p>
      CampusXI mobile app will be available on iOS App Store and Google Play
      Store. Use the buttons below once the store listings go live.
    </p>
    <p class="notice">
      If you need early access before the public launch, contact
      <a href="mailto:support@campusxi.com">support@campusxi.com</a>.
    </p>

    <div class="button-row">
      <a class="button" href="#" aria-disabled="true"
        >Download on App Store (Coming Soon)</a
      >
      <a class="button secondary" href="#" aria-disabled="true"
        >Get it on Google Play (Coming Soon)</a
      >
    </div>
  </section>

  <section class="card">
    <h2 class="section-title">Before You Install</h2>
    <ul class="list">
      <li>Create or sign in to your CampusXI account after installation.</li>
      <li>
        Review the Privacy Policy and Terms of Use before making purchases.
      </li>
      <li>For support or setup issues, visit Help Center.</li>
    </ul>
  </section>
</SiteLayout>
