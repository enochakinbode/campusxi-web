---
import SiteLayout from "../layouts/SiteLayout.astro";

const effectiveDate = "April 20, 2026";
---

<SiteLayout
  title="Terms of Use"
  description="Campus XI Terms of Use including purchases, passes, refund rules, and social card usage limits."
>
  <section class="card hero">
    <p class="badge">Legal</p>
    <h1>Terms of Use</h1>
    <p class="meta">Effective date: {effectiveDate}</p>
    <p>
      By using Campus XI, you agree to these Terms. If you do not agree, do not
      use the app.
    </p>
  </section>

  <section class="card">
    <h2 class="section-title">Eligibility and Accounts</h2>
    <ul class="list">
      <li>You are responsible for keeping your account credentials secure.</li>
      <li>You agree to provide accurate account and profile information.</li>
      <li>
        You are responsible for activity that happens through your account.
      </li>
    </ul>
  </section>

  <section class="card">
    <h2 class="section-title">Purchases, Passes, and Access</h2>
    <ul class="list">
      <li>Purchases unlock premium features shown at checkout.</li>
      <li>Pass pricing and feature packaging may change in future updates.</li>
      <li>
        Passes may be one-time, seasonal, or recurring depending on checkout
        details.
      </li>
      <li>
        Abuse, fraud, chargeback misuse, or policy violations may lead to
        revoked access.
      </li>
    </ul>
    <p class="notice">
      Unless required by law, purchases are non-refundable after activation. If
      a store or payment provider offers a separate refund process, that process
      applies.
    </p>
  </section>

  <section class="card">
    <h2 class="section-title">Social Cards</h2>
    <p>
      Users may generate and save shareable social cards for personal use.
      Commercial resale, impersonation, or misuse of Campus XI branding is
      prohibited.
    </p>
  </section>

  <section class="card">
    <h2 class="section-title">Service Changes and Availability</h2>
    <ul class="list">
      <li>
        We may update, suspend, or discontinue features with or without notice.
      </li>
      <li>
        We are not liable for interruptions caused by third-party providers.
      </li>
      <li>You are responsible for your network or device access costs.</li>
    </ul>
  </section>

  <section class="card">
    <h2 class="section-title">Contact</h2>
    <p>
      Questions about these Terms can be sent to
      <a href="mailto:support@campusxi.com">support@campusxi.com</a>.
    </p>
  </section>
</SiteLayout>
